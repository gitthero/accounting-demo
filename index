// ══ LEDGER ══
function renderLedger(){
  const mon=document.getElementById('selMon').value;
  const carry=parseInt(document.getElementById('carryAmt').value)||0;
  let data=mon==='전체'?LEDGER:LEDGER.filter(r=>r.mon===mon);
  const tbody=document.getElementById('ledgerBody');
  tbody.innerHTML='';
  let bal=carry,totInc=carry,totExp=0;
  const smap={approved:'<span class="sb sb-ok">✓ 승인</span>',pending:'<span class="sb sb-wait">⏳ 대기</span>',rejected:'<span class="sb sb-no">✗ 반려</span>',draft:'<span class="sb sb-draft">📝 작성중</span>'};

  data.forEach((row,i)=>{
    bal+=row.income-row.expense;
    totInc+=row.income;totExp+=row.expense;
    const isAuditEnabled=auditActive&&(CU.role==='auditor'||['master','sub_master'].includes(CU.role));
    const auditCell=isAuditEnabled?
      `<div class="audit-check">
        <input type="radio" name="audit_${i}" id="aud_${i}" ${row.audited?'checked':''} onchange="markAudit(${i},this)">
        <label for="aud_${i}">${row.audited?'✅확인':'체크'}</label>
      </div>`:
      `<span style="font-size:11px;color:var(--text3)">${row.audited?'✅확인':'—'}</span>`;

    const tr=document.createElement('tr');
    if(row.audited)tr.className='audited';
    tr.innerHTML=`
      <td class="tc">${row.date}</td>
      <td>${row.cat}</td>
      <td style="font-size:11px">${row.detail||'-'}</td>
      <td>${row.memo}</td>
      <td class="tc">${row.rno!=='-'?`<span class="sb sb-draft" style="cursor:pointer" onclick="showRec('R-${row.rno.padStart(4,'0')}','${row.date}','${row.cat}','${row.memo}','${row.expense}')">🧾 #${row.rno}</span>`:'-'}</td>
      <td class="tnum">${row.income?row.income.toLocaleString():'-'}</td>
      <td class="tnum">${row.expense?'<span style="color:var(--red)">-'+row.expense.toLocaleString()+'</span>':'-'}</td>
      <td class="tnum" style="color:${bal<0?'var(--red)':'var(--green);font-weight:700'}">${bal.toLocaleString()}</td>
      <td class="tc">${smap[row.status]||''}</td>
      <td class="tc no-print">${auditCell}</td>
    `;
    tbody.appendChild(tr);
  });

  const sub=document.createElement('tr');sub.className='tsub';
  sub.innerHTML=`<td colspan="5" class="tc">${mon==='전체'?'합':'월'} 소 계</td><td class="tnum">${totInc.toLocaleString()}</td><td class="tnum" style="color:var(--red)">${totExp.toLocaleString()}</td><td class="tnum">${(totInc-totExp).toLocaleString()}</td><td></td><td class="no-print"></td>`;
  tbody.appendChild(sub);
  const tot=document.createElement('tr');tot.className='ttot';
  tot.innerHTML=`<td colspan="5" class="tc">누 계 (이월금 포함)</td><td class="tnum">${totInc.toLocaleString()}</td><td class="tnum">${totExp.toLocaleString()}</td><td class="tnum" style="color:${bal<0?'var(--red)':'var(--green)'};font-weight:900">${bal.toLocaleString()}</td><td></td><td class="no-print"></td>`;
  tbody.appendChild(tot);

  const budget=3000000;
  const comm2=document.getElementById('selComm').value;
  const dept2=document.getElementById('selDept').value;
  const realBdg=getBudgetTotal(comm2,dept2)||3000000;
  document.getElementById('cBudget').textContent=realBdg.toLocaleString();
  document.getElementById('cCarry').textContent=carry.toLocaleString();
  document.getElementById('cExp').textContent=totExp.toLocaleString();
  document.getElementById('cBal').textContent=(realBdg+carry-totExp).toLocaleString();
  document.getElementById('cProg').style.width=Math.min(100,Math.round(totExp/(realBdg+carry||1)*100))+'%';
  document.getElementById('ledgerTableTitle').textContent=`📋 ${mon} 지출내역`;
}

function markAudit(i,el){
  if(!auditActive){el.checked=false;return;}
  LEDGER[i].audited=el.checked;
  renderLedger();
  if(el.checked)showNotif('감사 확인 완료 ✅',`${CU.name} 서명 기록 (${new Date().toLocaleString()})`);
}

// ══ MONTHLY ══
function buildMonthly(){
  const cats={};
  LEDGER.forEach(r=>{
    if(r.expense>0){
      const k=r.cat+'::'+r.detail;
      if(!cats[k])cats[k]={cat:r.cat,detail:r.detail,count:0,total:0};
      cats[k].count++;cats[k].total+=r.expense;
    }
  });
  const total=Object.values(cats).reduce((a,v)=>a+v.total,0);
  const tbody=document.getElementById('monthlyBody');
  tbody.innerHTML='';
  Object.values(cats).forEach(v=>{
    const tr=document.createElement('tr');
    tr.innerHTML=`<td>${v.cat}</td><td style="font-size:11px">${v.detail||'-'}</td><td class="tc">${v.count}건</td>
      <td class="tnum" style="color:var(--red)">${v.total.toLocaleString()}</td>
      <td class="tc"><div class="prog" style="width:80px;display:inline-block"><div class="pf pfr" style="width:${Math.round(v.total/total*100)}%"></div></div> ${Math.round(v.total/total*100)}%</td>`;
    tbody.appendChild(tr);
  });
  const tr2=document.createElement('tr');tr2.className='ttot';
  tr2.innerHTML=`<td colspan="3" class="tc">합 계</td><td class="tnum">${total.toLocaleString()}</td><td class="tc">100%</td>`;
  tbody.appendChild(tr2);

  // 감사 서명 버튼 (감사기간 중 감사위원)
  const showAuditBtn=auditActive&&(CU.role==='auditor'||['master','sub_master'].includes(CU.role));
  document.getElementById('auditSignBtn').style.display=showAuditBtn?'block':'none';
  document.getElementById('auditSignBtn2').style.display=showAuditBtn?'block':'none';
}

// ══ ANNUAL ══
function buildAnnual(comm,dept){
  const cats=comm&&dept&&DB[comm]&&DB[comm][dept]?Object.keys(DB[comm][dept]):['예배비','교육비','수련회','행사비','친교비','운영비'];
  const head=document.getElementById('annualHead');
  head.innerHTML=`<th>월</th><th>수입(a)</th>${cats.map(c=>`<th>${c}</th>`).join('')}<th>지출소계(b)</th><th>잔액(a-b)</th>`;
  const months=['1월','2월','3월','4월','5월','6월','7월','8월','9월','10월','11월','12월'];
  const tbody=document.getElementById('annualBody');tbody.innerHTML='';
  let totI=0,totCols=Array(cats.length).fill(0);
  months.forEach((m,i)=>{
    const inc=i===0?3000000:0;
    const cols=cats.map((_,j)=>i===1&&j<4?[320000,197250,475000,35000][j]||0:0);
    const sub=cols.reduce((a,b)=>a+b,0);
    totI+=inc;cols.forEach((v,j)=>totCols[j]+=v);
    const tr=document.createElement('tr');
    if(i>=2)tr.style.color='var(--text3)';
    tr.innerHTML=`<td class="tc" style="font-weight:700">${m}</td><td class="tnum">${inc?inc.toLocaleString():'-'}</td>${cols.map(v=>`<td class="tnum">${v?v.toLocaleString():'-'}</td>`).join('')}<td class="tnum" style="color:var(--red);font-weight:700">${sub?sub.toLocaleString():'-'}</td><td class="tnum" style="color:${inc?(inc-sub<0?'var(--red)':'var(--green)'):'var(--text3)'};font-weight:700">${inc?(inc-sub).toLocaleString():'-'}</td>`;
    tbody.appendChild(tr);
  });
  const totSub=totCols.reduce((a,b)=>a+b,0);
  const ttr=document.createElement('tr');ttr.className='ttot';
  ttr.innerHTML=`<td class="tc">합 계</td><td class="tnum">${totI.toLocaleString()}</td>${totCols.map(v=>`<td class="tnum">${v?v.toLocaleString():'-'}</td>`).join('')}<td class="tnum">${totSub.toLocaleString()}</td><td class="tnum">${(totI-totSub).toLocaleString()}</td>`;
  tbody.appendChild(ttr);
  document.getElementById('annualPrintTitle').textContent=`2025년도 ${dept||''} 연간 예산집행현황`;
}

