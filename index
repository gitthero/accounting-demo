  const selDeptVal=document.getElementById('selDept').value;
  if(selDeptVal)onDeptChange();
}

function getBudgetTotal(comm,dept){
  if(!BUDGET||!BUDGET[comm]||!BUDGET[comm][dept])return 0;
  return Object.values(BUDGET[comm][dept]).reduce((a,b)=>a+b,0);
}

