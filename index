}
function closeRecModal(){document.getElementById('recModal').classList.remove('show');}

// ══ PRINT ══
function showPrintModal(target){
  printTarget=target;
  document.getElementById('printModal').classList.add('show');
  // 자동 방향 추천
  if(target==='annual'||target==='integrated'){
    setPrintDir('landscape');
  } else {
    setPrintDir('portrait');
  }
}
function closePrintModal(){document.getElementById('printModal').classList.remove('show');}
function setPrintDir(dir){
  printDirection=dir;
  document.getElementById('pLand').classList.toggle('selected',dir==='landscape');
  document.getElementById('pPort').classList.toggle('selected',dir==='portrait');
  document.getElementById('prevDir').textContent=dir==='landscape'?'가로':'세로';
}
function doPrint(){
  const style=document.createElement('style');
  style.id='printStyle';
  style.textContent=printDirection==='landscape'?
    '@page{size:B5 landscape;margin:10mm}':
    '@page{size:B5 portrait;margin:10mm}';
  const existing=document.getElementById('printStyle');
  if(existing)existing.remove();
  document.head.appendChild(style);
  closePrintModal();
  setTimeout(()=>window.print(),200);
}

