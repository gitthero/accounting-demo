function onCommChange(){
  const comm=document.getElementById('selComm').value;
  const sel=document.getElementById('selDept');
  sel.innerHTML='';
  if(!comm||!DB[comm])return;
  let depts=Object.keys(DB[comm]).sort();
  const isFull=['master','sub_master','pastor'].includes(CU.role);
  const isChair=CU.role==='chair';
  // 회계/부장: 본인 부서만! (엄격 제한)
  if(['acc','chief'].includes(CU.role)){
    depts=depts.filter(d=>d===CU.dept);
  }
  // 위원장: 해당 위원회 전체 부서
  // 마스터/당회장: 전체
  depts.forEach(d=>{
    const o=document.createElement('option');
    o.value=d;
    // 예산 금액도 표시
    const bdg=getBudgetTotal(comm,d);
    o.textContent=d+(bdg?` (${bdg.toLocaleString()}원)`:'');
    if(d===CU.dept||depts.length===1)o.selected=true;
    sel.appendChild(o);
  });
