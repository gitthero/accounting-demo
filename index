// ══ RECEIPT ══
function showRec(num,date,cat,memo,amt){
  document.getElementById('ri1').textContent=num;
  document.getElementById('ri2').textContent='2025.'+date;
  document.getElementById('ri3').textContent=cat;
  document.getElementById('ri4').textContent=parseInt(amt).toLocaleString()+'원';
