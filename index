function pastorApprove(btn){
  const row=btn.closest('tr');
  row.cells[7].innerHTML='<span class="sb sb-ok">✅ 승인완료</span>';
  btn.remove();
  const pending=parseInt(document.getElementById('pastorPending').textContent);
  const done=parseInt(document.getElementById('pastorDone').textContent);
  document.getElementById('pastorPending').textContent=Math.max(0,pending-1);
  document.getElementById('pastorDone').textContent=done+1;
  document.getElementById('pbadge').textContent=Math.max(0,pending-1);
  showNotif('사후승인 완료 👑','재정부회계에게 승인완료 알림 발송');
}

function batchApprove(){
  const chks=document.querySelectorAll('.pastor-chk:checked');
  if(chks.length===0){showNotif('선택된 결의서가 없습니다','체크박스를 선택하세요');return;}
  chks.forEach(c=>{
    const row=c.closest('tr');
    row.cells[7].innerHTML='<span class="sb sb-ok">✅ 승인완료</span>';
    c.closest('td').innerHTML='';
  });
  showNotif(`일괄 사후승인 완료 👑 (${chks.length}건)`,'재정부회계에게 승인완료 알림 발송');
}

function checkAll(cb){
  document.querySelectorAll('.pastor-chk').forEach(c=>c.checked=cb.checked);
}

// ══ AUDIT ══
function buildAuditPage(){
  const tbody=document.getElementById('auditBody');
  tbody.innerHTML='';
  const comms=CU.role==='auditor'?[CU.scope]:Object.keys(COMMITTEES).slice(0,5);
  comms.forEach(comm=>{
    if(!comm||!DB[comm])return;
    Object.keys(DB[comm]).forEach(dept=>{
      const tr=document.createElement('tr');
      tr.innerHTML=`<td>${comm}</td><td>${dept}</td>
        <td class="tc">${auditActive?'<button class="btn bs btn-sm" onclick="auditSign(\'monthly\')">🔍 서명</button>':'<span class="sb sb-draft">비활성</span>'}</td>
        <td class="tc">${auditActive?'<button class="btn bo btn-sm" onclick="auditSign(\'annual\')">🔍 서명</button>':'<span class="sb sb-draft">비활성</span>'}</td>
        <td class="tc">${auditActive?'<span class="sb sb-wait">활성화됨</span>':'<span class="sb sb-draft">비활성</span>'}</td>`;
      tbody.appendChild(tr);
    });
  });
  document.getElementById('auditPeriod').textContent=auditActive?`감사중 (${auditInfo.start})`:'-';
  document.getElementById('auditSub').textContent=CU.scope?`담당: ${CU.scope}`:'전체 위원회 감사';
}

function auditSign(type){
  if(!auditActive){showNotif('감사 기간이 아닙니다','마스터가 감사기간을 설정해야 합니다');return;}
  const typeStr=type==='monthly'?'월간결산':'연간결산';
  if(confirm(`${typeStr} 감사 확인 서명을 하시겠습니까?\n\n서명자: ${CU.name}\n일시: ${new Date().toLocaleString()}`)){
    document.getElementById('auditSignedInfo').style.display='block';
    document.getElementById('auditSignedInfo').textContent=`✅ ${typeStr} 감사 확인 완료 | 서명: ${CU.name} | 일시: ${new Date().toLocaleString()}`;
    showNotif(`${typeStr} 감사 서명 완료 ✅`,`${CU.name} 전자서명 기록`);
  }
}

// ══ AUDIT PERIOD ══
function startAudit(){
  const start=document.getElementById('auditStart').value;
  const end=document.getElementById('auditEnd').value;
  const term=document.getElementById('auditTerm').value;
  if(!start||!end){alert('날짜를 입력하세요');return;}
  auditActive=true;
  auditInfo={start,end,term};
  document.getElementById('auditBanner').style.display='flex';
  document.getElementById('auditBannerMsg').textContent=`${term} 정기감사 진행 중 (${start} ~ ${end})`;
  showNotif('감사 기간 시작 🔍',`${term} | ${start} ~ ${end}`);
  buildAuditPage();
  renderLedger();
  buildMonthly();
}

function endAudit(){
  auditActive=false;
  document.getElementById('auditBanner').style.display='none';
  showNotif('감사 기간 종료 ✅','감사가 완료되었습니다');
  buildAuditPage();
  renderLedger();
  buildMonthly();
}

