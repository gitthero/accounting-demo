}

function doProxy(btn){
  const row=btn.closest('tr');
  const reason=prompt('전결 사유를 입력하세요:');
  if(reason){
    row.cells[6].innerHTML='<span class="sb sb-purple">전결</span>';
    showNotif('전결 처리 완료 📌',`전결사유: ${reason} | ${CU.name} 전자서명`);
