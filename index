function setupApp(){
  const u=CU;
  document.getElementById('tbName').textContent=u.name;
  document.getElementById('tbComm').textContent=u.committee+(u.dept!=='-'?' | '+u.dept:'');

  const isMgr=['master','sub_master'].includes(u.role);
  const isPastor=u.role==='pastor';
  const isAuditor=u.role==='auditor';

  document.getElementById('nav-admin').style.display=isMgr?'block':'none';
  document.getElementById('nav-pastor').style.display=isPastor||isMgr?'block':'none';
  document.getElementById('ndiv-pastor').style.display=isPastor||isMgr?'block':'none';
  document.getElementById('nav-audit').style.display=isAuditor||isMgr?'block':'none';
  document.getElementById('ndiv-audit').style.display=isAuditor||isMgr?'block':'none';
  document.getElementById('nav-integrated').style.display=isMgr||isPastor?'':'none';

  // 결재함 배지
  if(['chair','chief','fin_chief','fin_acc','fin_chair'].includes(u.role)){
    document.getElementById('abadge').style.display='inline';
  }

  // 감사 배너
  if(auditActive){
    document.getElementById('auditBanner').style.display='flex';
    document.getElementById('auditBannerMsg').textContent=`${auditInfo.term} 정기감사 진행 중 (${auditInfo.start} ~ ${auditInfo.end})`;
  }

  // 위원회 셀렉트 빌드
  buildCommSelect();
  buildApprovalFlow();
  buildVoucherList();
  buildApprovalPending();
  buildPastorList();
  buildIntegrated();
  buildBudget();
  buildUsers();
  buildAuditorList();
  buildSpecial();
  buildAuditPage();

  // ★ 로그인 후 위원회/부서 자동선택
  if(u.committee && u.committee!=='전체' && DB[u.committee]){
    const sc=document.getElementById('selComm');
    if(sc) sc.value=u.committee;
    onCommChange();
    if(u.dept && u.dept!=='-'){
      setTimeout(()=>{
        const sd=document.getElementById('selDept');
        if(sd){ sd.value=u.dept; onDeptChange(); }
      },150);
    }
  }

  // 기본 화면 설정
  if(isPastor){sp('pastor',document.querySelector('[onclick*="pastor"]'));}
  else if(isAuditor){sp('audit',document.querySelector('[onclick*="audit"]'));}
}

