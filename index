<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>교회 회계 장부 시스템 v3.0</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700;900&family=Noto+Serif+KR:wght@400;600;700;900&display=swap');

:root {
  --bg:#f0ede8;--white:#fff;--surface:#faf8f5;--border:#ddd8cf;--border2:#c8c0b4;
  --navy:#1a3a5c;--navy2:#0f2540;--blue:#2c5f8a;--blue-light:#e8f0f7;
  --green:#2d7a4f;--green-light:#e8f5ee;--red:#c0392b;--red-light:#fdf0ee;
  --gold:#b5860d;--gold-light:#fdf8e8;--purple:#6b4c9a;--purple-light:#f0ebf8;
  --orange:#d4650a;--orange-light:#fdf2e8;
  --text:#1a1a1a;--text2:#4a4a4a;--text3:#888;
  --shadow:0 2px 16px rgba(0,0,0,.08);--shadow2:0 8px 32px rgba(0,0,0,.15);
  --radius:12px;--radius2:8px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Noto Sans KR',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;}

/* ══ STEP 1 LOGIN ══ */
#step1{min-height:100vh;display:flex;align-items:center;justify-content:center;
  background:linear-gradient(135deg,#0f2540 0%,#1a3a5c 40%,#2c5f8a 100%);
  position:relative;overflow:hidden;}
#step1::before{content:'';position:absolute;inset:0;
  background:radial-gradient(ellipse at 30% 50%,rgba(44,95,138,.3) 0%,transparent 60%),
             radial-gradient(ellipse at 70% 20%,rgba(181,134,13,.15) 0%,transparent 50%);}
.s1-box{background:var(--white);border-radius:20px;padding:48px 44px;width:100%;max-width:460px;
  position:relative;box-shadow:0 24px 64px rgba(0,0,0,.35);}
.s1-logo{text-align:center;margin-bottom:32px;padding-bottom:24px;border-bottom:2px solid var(--border);}
.s1-logo .cross{font-size:40px;display:block;margin-bottom:10px;}
.s1-logo h1{font-family:'Noto Serif KR',serif;font-size:21px;font-weight:900;color:var(--navy2);letter-spacing:-0.5px;}
.s1-logo p{font-size:12px;color:var(--text3);margin-top:5px;}
.s1-logo .ver{display:inline-block;background:var(--navy);color:white;font-size:10px;padding:2px 8px;border-radius:10px;margin-top:6px;font-weight:700;}
.ig{margin-bottom:14px;}
.ig label{font-size:12px;color:var(--text2);display:block;margin-bottom:5px;font-weight:700;}
.ig input{width:100%;padding:12px 14px;border:2px solid var(--border);border-radius:var(--radius2);
  font-size:14px;font-family:inherit;color:var(--text);outline:none;transition:border-color .2s;}
.ig input:focus{border-color:var(--blue);}
.btn-login{width:100%;padding:14px;background:linear-gradient(135deg,var(--navy),var(--blue));
  border:none;border-radius:var(--radius2);color:white;font-size:15px;font-weight:800;
  cursor:pointer;font-family:inherit;transition:all .2s;letter-spacing:.5px;
  box-shadow:0 4px 16px rgba(26,58,92,.3);}
.btn-login:hover{transform:translateY(-1px);box-shadow:0 6px 20px rgba(26,58,92,.4);}
.hint{text-align:center;font-size:11px;color:var(--text3);margin-top:14px;}

/* ══ STEP 2 위원회 선택 ══ */
#step2{min-height:100vh;display:none;background:var(--bg);}
.s2-header{background:linear-gradient(135deg,var(--navy2),var(--navy));padding:28px 24px;text-align:center;}
.s2-header h2{font-family:'Noto Serif KR',serif;color:white;font-size:22px;font-weight:900;}
.s2-header p{color:rgba(255,255,255,.7);font-size:13px;margin-top:6px;}
.s2-body{padding:28px 20px;max-width:900px;margin:0 auto;}
.s2-section{margin-bottom:28px;}
.s2-section-title{font-size:11px;color:var(--text3);font-weight:800;letter-spacing:1px;
  text-transform:uppercase;margin-bottom:12px;padding-left:4px;}
.comm-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(118px,1fr));gap:8px;}
.comm-tile{background:var(--white);border:2px solid var(--border);border-radius:var(--radius);
  padding:13px 10px;text-align:center;cursor:pointer;transition:all .2s;
  box-shadow:var(--shadow);}
.comm-tile:hover{border-color:var(--blue);transform:translateY(-2px);box-shadow:var(--shadow2);}
.comm-tile .ico{font-size:22px;display:block;margin-bottom:6px;}
.comm-tile .name{font-size:11px;font-weight:700;color:var(--navy);line-height:1.4;}
.comm-tile .sub{font-size:10px;color:var(--text3);margin-top:2px;}
.special-tiles{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:8px;}
.special-tile{background:linear-gradient(135deg,var(--navy),var(--blue));border-radius:var(--radius);
  padding:14px 16px;cursor:pointer;transition:all .2s;box-shadow:var(--shadow);
  display:flex;align-items:center;gap:12px;}
.special-tile:hover{transform:translateY(-2px);box-shadow:var(--shadow2);}
.special-tile .ico{font-size:24px;}
.special-tile .info .name{font-size:13px;font-weight:800;color:white;}
.special-tile .info .sub{font-size:10px;color:rgba(255,255,255,.7);margin-top:2px;}
/* 당회장 특별 타일 */
.pastor-tile{background:linear-gradient(135deg,#6b1a1a,#b5250d)!important;}
/* 재정/감사 타일 */
.fin-tile{background:linear-gradient(135deg,#0a4a2e,#1a7a4e)!important;}
.audit-tile{background:linear-gradient(135deg,#3a1a6e,#6b3aaa)!important;}
/* 커스텀 아이콘 SVG */
.ico-svg{width:26px;height:26px;display:block;margin:0 auto 6px;}

/* ══ STEP 3 위원회 로그인 ══ */
#step3{min-height:100vh;display:none;align-items:center;justify-content:center;
  background:linear-gradient(135deg,#0f2540,#1a3a5c,#2c5f8a);}
.s3-box{background:var(--white);border-radius:20px;padding:40px;width:100%;max-width:420px;
  box-shadow:0 24px 64px rgba(0,0,0,.35);}
.s3-back{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--text3);
  cursor:pointer;margin-bottom:24px;border:none;background:none;font-family:inherit;}
.s3-back:hover{color:var(--blue);}
.s3-comm-badge{display:flex;align-items:center;gap:12px;background:var(--blue-light);
  border-radius:var(--radius);padding:14px 16px;margin-bottom:24px;}
.s3-comm-badge .ico{font-size:28px;}
.s3-comm-badge h3{font-size:15px;font-weight:800;color:var(--navy);}
.s3-comm-badge p{font-size:11px;color:var(--text3);margin-top:2px;}
.role-hint{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius2);
  padding:12px 14px;margin-bottom:18px;}
.role-hint p{font-size:11px;color:var(--text3);margin-bottom:6px;font-weight:700;}
.role-list{display:flex;flex-wrap:wrap;gap:5px;}
.rbadge{font-size:10px;padding:3px 8px;border-radius:10px;font-weight:700;}
.rm{background:#fdf0ee;color:var(--red);}
.rc{background:#fdf8e8;color:var(--gold);}
.rch{background:var(--blue-light);color:var(--blue);}
.ra{background:var(--green-light);color:var(--green);}
.rau{background:var(--purple-light);color:var(--purple);}
.rp{background:var(--orange-light);color:var(--orange);}

/* ══ APP ══ */
#app{display:none;}
.topbar{position:fixed;top:0;left:0;right:0;height:56px;
  background:linear-gradient(135deg,var(--navy2),var(--navy));
  display:flex;align-items:center;padding:0 18px;gap:12px;z-index:200;
  box-shadow:0 2px 12px rgba(0,0,0,.25);}
.topbar-title{font-family:'Noto Serif KR',serif;color:white;font-size:15px;font-weight:700;flex:1;}
.topbar-user{color:rgba(255,255,255,.8);font-size:11px;text-align:right;line-height:1.4;}
.topbar-user strong{color:white;display:block;font-size:13px;}
.topbar-role{font-size:10px;padding:1px 7px;border-radius:10px;font-weight:700;margin-left:4px;}
.menu-btn{background:transparent;border:none;color:white;font-size:20px;cursor:pointer;}

/* ══ SIDEBAR ══ */
.sidebar{position:fixed;left:0;top:56px;bottom:0;width:220px;
  background:var(--white);border-right:1px solid var(--border);
  overflow-y:auto;z-index:100;transition:transform .3s;}
.ns{padding:10px 8px 2px;}
.nsl{font-size:10px;color:var(--text3);font-weight:800;letter-spacing:.8px;
  text-transform:uppercase;padding:0 8px 5px;}
.nb{display:flex;align-items:center;gap:8px;width:100%;padding:9px 12px;
  border-radius:var(--radius2);border:none;background:transparent;
  color:var(--text2);font-size:13px;cursor:pointer;font-family:inherit;
  transition:all .15s;margin-bottom:1px;text-align:left;}
.nb:hover{background:var(--blue-light);color:var(--blue);}
.nb.active{background:var(--navy);color:white;font-weight:700;}
.nb .ico{width:18px;text-align:center;font-size:14px;}
.nb .badge{margin-left:auto;background:var(--red);color:white;
  border-radius:10px;padding:1px 6px;font-size:10px;font-weight:700;}
.ndiv{height:1px;background:var(--border);margin:5px 8px;}

/* ══ MAIN ══ */
.main{margin-left:220px;padding-top:56px;min-height:100vh;}
.page{display:none;padding:24px;}
.page.active{display:block;animation:fadeUp .25s ease;}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ══ PAGE HEADER ══ */
.ph{display:flex;align-items:flex-start;justify-content:space-between;
  margin-bottom:20px;flex-wrap:wrap;gap:10px;}
.ph-left h2{font-family:'Noto Serif KR',serif;font-size:22px;font-weight:900;color:var(--navy2);}
.ph-left p{font-size:12px;color:var(--text3);margin-top:3px;}
.ph-right{display:flex;gap:7px;flex-wrap:wrap;}

/* ══ BUTTONS ══ */
.btn{padding:8px 15px;border-radius:var(--radius2);border:none;cursor:pointer;
  font-size:13px;font-weight:700;font-family:inherit;transition:all .15s;
  display:inline-flex;align-items:center;gap:5px;}
.bp{background:var(--navy);color:white;}.bp:hover{background:var(--navy2);}
.bs{background:var(--green);color:white;}
.bd{background:var(--red);color:white;}
.bg{background:var(--gold);color:white;}
.bo{background:white;border:2px solid var(--border2);color:var(--text2);}
.bo:hover{border-color:var(--blue);color:var(--blue);}
.bpr{background:var(--gold-light);border:2px solid var(--gold);color:var(--gold);}
.bpr:hover{background:var(--gold);color:white;}
.btn-sm{padding:5px 9px;font-size:11px;}

/* ══ SUMMARY CARDS ══ */
.sc{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:14px;margin-bottom:20px;}
.scard{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);
  padding:16px 18px;box-shadow:var(--shadow);}
.scard .lbl{font-size:11px;color:var(--text3);font-weight:700;margin-bottom:6px;}
.scard .val{font-size:20px;font-weight:900;letter-spacing:-.5px;}
.scard .sub{font-size:11px;color:var(--text3);margin-top:3px;}
.cb{border-top:3px solid var(--blue);}.cg{border-top:3px solid var(--green);}
.cr{border-top:3px solid var(--red);}.co{border-top:3px solid var(--gold);}
.cp{border-top:3px solid var(--purple);}
.vb{color:var(--blue);}.vg{color:var(--green);}.vr{color:var(--red);}
.vo{color:var(--gold);}.vp{color:var(--purple);}
.prog{height:5px;background:var(--border);border-radius:3px;margin-top:8px;overflow:hidden;}
.pf{height:100%;border-radius:3px;}
.pfb{background:var(--blue);}.pfg{background:var(--green);}.pfr{background:var(--red);}

/* ══ FILTER BAR ══ */
.fb{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);
  padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;
  gap:10px;flex-wrap:wrap;box-shadow:var(--shadow);}
.fb label{font-size:12px;color:var(--text2);font-weight:700;white-space:nowrap;}
.fb select,.fb input[type=text],.fb input[type=date]{
  padding:7px 10px;border:2px solid var(--border);border-radius:var(--radius2);
  font-size:13px;font-family:inherit;color:var(--text);background:var(--white);outline:none;transition:border-color .2s;}
.fb select:focus,.fb input:focus{border-color:var(--blue);}

/* ══ TABLE ══ */
.tw{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);
  overflow:hidden;box-shadow:var(--shadow);margin-bottom:18px;}
.th{padding:14px 18px;border-bottom:1px solid var(--border);
  display:flex;align-items:center;justify-content:space-between;background:var(--surface);}
.th h3{font-size:14px;font-weight:800;color:var(--navy2);}
.ts{overflow-x:auto;}
table{width:100%;border-collapse:collapse;font-size:13px;}
thead tr{background:#ece9e2;}
th{padding:10px 12px;text-align:center;font-size:11px;color:var(--text2);
  font-weight:800;border-bottom:2px solid var(--border2);white-space:nowrap;}
td{padding:9px 12px;border-bottom:1px solid #f0ede8;vertical-align:middle;}
tr:last-child td{border-bottom:none;}
tr:hover td{background:#fafaf7;}
.tc{text-align:center;}.tr2{text-align:right;}
.tnum{font-family:monospace;text-align:right;}
.tsub td{background:#f0ede8;font-weight:800;border-top:2px solid var(--border2);}
.ttot td{background:var(--blue-light);font-weight:900;color:var(--navy2);border-top:2px solid var(--blue);}

/* ══ STATUS BADGE ══ */
.sb{display:inline-flex;align-items:center;gap:3px;padding:3px 8px;
  border-radius:20px;font-size:11px;font-weight:700;white-space:nowrap;}
.sb-ok{background:var(--green-light);color:var(--green);}
.sb-wait{background:var(--gold-light);color:var(--gold);}
.sb-no{background:var(--red-light);color:var(--red);}
.sb-draft{background:#f0ede8;color:var(--text3);}
.sb-purple{background:var(--purple-light);color:var(--purple);}
.sb-blue{background:var(--blue-light);color:var(--blue);}

/* ══ FORM CARD ══ */
.fc{background:var(--white);border:1px solid var(--border);border-radius:var(--radius);
  overflow:hidden;box-shadow:var(--shadow);margin-bottom:18px;}
.fch{padding:14px 18px;background:linear-gradient(135deg,var(--navy),var(--blue));
  color:white;font-size:14px;font-weight:800;}
.fb2{padding:20px;}
.fgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(175px,1fr));gap:14px;}
.fg{margin-bottom:0;}
.fg.full{grid-column:1/-1;}
.fg.w2{grid-column:span 2;}
.fg label{font-size:11px;color:var(--text2);font-weight:800;display:block;margin-bottom:5px;}
.fg input,.fg select,.fg textarea{width:100%;padding:9px 12px;border:2px solid var(--border);
  border-radius:var(--radius2);font-size:13px;font-family:inherit;color:var(--text);
  background:var(--white);outline:none;transition:border-color .2s;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--blue);}
.fg textarea{resize:vertical;min-height:60px;}
.faction{padding:14px 18px;border-top:1px solid var(--border);
  display:flex;gap:8px;background:var(--surface);flex-wrap:wrap;}

/* ══ AUDIT CHECKBOX ══ */
.audit-check{display:flex;align-items:center;justify-content:center;gap:4px;}
.audit-check input[type=radio]{width:16px;height:16px;cursor:pointer;accent-color:var(--green);}
.audit-check label{font-size:10px;color:var(--text3);cursor:pointer;}
.audited{background:var(--green-light)!important;}
.audited td{color:var(--green);}

/* ══ VOUCHER (지출결의서) ══ */
.voucher{background:var(--white);border:2px solid var(--navy);border-radius:var(--radius);
  padding:28px;max-width:700px;margin:0 auto;}
.voucher-title{text-align:center;margin-bottom:20px;}
.voucher-title h2{font-family:'Noto Serif KR',serif;font-size:26px;font-weight:900;
  letter-spacing:4px;border-bottom:3px solid var(--navy);padding-bottom:10px;display:inline-block;}
.voucher-info{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:16px;}
.voucher-approval{border:2px solid var(--navy);}
.voucher-approval table{margin:0;}
.voucher-approval th{background:#f0ede8;font-size:11px;padding:6px 14px;border:1px solid var(--navy);}
.voucher-approval td{font-size:11px;padding:20px 14px;border:1px solid var(--navy);text-align:center;}
.voucher-table{width:100%;border-collapse:collapse;margin-bottom:14px;}
.voucher-table th{border:2px solid var(--navy);padding:8px 10px;font-size:12px;
  background:#f0ede8;text-align:center;}
.voucher-table td{border:1px solid var(--navy);padding:8px 10px;font-size:12px;}
.voucher-bottom{text-align:center;margin:16px 0;}
.voucher-sign{display:flex;justify-content:flex-end;margin-top:16px;}
.sign-table{border-collapse:collapse;}
.sign-table th{border:2px solid var(--navy);padding:6px 16px;font-size:11px;background:#f0ede8;}
.sign-table td{border:1px solid var(--navy);padding:20px 16px;font-size:11px;text-align:center;}

/* ══ APPROVAL FLOW ══ */
.flow{display:flex;align-items:center;gap:0;overflow-x:auto;padding:14px 0;margin-bottom:18px;}
.flow-step{text-align:center;min-width:90px;}
.flow-step .circle{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;
  justify-content:center;font-size:18px;margin:0 auto 6px;border:3px solid var(--border);}
.flow-step .name{font-size:10px;font-weight:700;color:var(--text3);}
.flow-step .status{font-size:9px;margin-top:2px;}
.flow-arrow{font-size:18px;color:var(--border2);margin:0 4px;padding-bottom:20px;}
.step-done .circle{background:var(--green-light);border-color:var(--green);}
.step-done .name{color:var(--green);}
.step-active .circle{background:var(--gold-light);border-color:var(--gold);animation:pulse .8s infinite;}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(181,134,13,.4)}50%{box-shadow:0 0 0 6px rgba(181,134,13,0)}}
.step-active .name{color:var(--gold);}
.step-wait .circle{background:#f5f3ee;border-color:var(--border2);}

/* ══ PRINT ══ */
@media print {
  #step1,#step2,#step3{display:none!important;}
  .topbar,.sidebar,.ph-right,.fb,.no-print,
  .nb,.ndiv,.ns{display:none!important;}
  .main{margin-left:0!important;padding-top:0!important;}
  .page{padding:8px!important;}
  .print-header{display:block!important;}
  @page{size:B5 landscape;margin:10mm;}
  @page.portrait{size:B5 portrait;}
  table{font-size:9px;}
  th,td{padding:4px 5px!important;}
  .tw{box-shadow:none!important;border:1px solid #999!important;}
}
.print-header{display:none;text-align:center;margin-bottom:14px;}
.print-header h2{font-family:'Noto Serif KR',serif;font-size:17px;font-weight:900;}
.print-header p{font-size:11px;color:#666;margin-top:3px;}

/* ══ PRINT PREVIEW MODAL ══ */
.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:2000;
  display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px);}
.modal-bg.show{display:flex;animation:fadeUp .2s ease;}
.modal{background:var(--white);border-radius:20px;width:90%;max-width:480px;
  overflow:hidden;box-shadow:0 24px 64px rgba(0,0,0,.35);}
.modal-head{background:linear-gradient(135deg,var(--navy),var(--blue));color:white;
  padding:16px 20px;display:flex;align-items:center;justify-content:space-between;}
.modal-head h3{font-size:15px;font-weight:800;}
.modal-close{background:none;border:none;color:white;font-size:22px;cursor:pointer;}
.modal-body{padding:24px;}
.print-opt{margin-bottom:18px;}
.print-opt label{font-size:12px;font-weight:800;color:var(--text2);display:block;margin-bottom:10px;}
.print-btns{display:flex;gap:8px;}
.popt-btn{flex:1;padding:12px 8px;border:2px solid var(--border2);border-radius:var(--radius2);
  background:var(--white);cursor:pointer;font-family:inherit;font-size:12px;font-weight:700;
  color:var(--text2);transition:all .2s;text-align:center;}
.popt-btn:hover,.popt-btn.selected{border-color:var(--navy);background:var(--navy);color:white;}
.preview-box{background:var(--bg);border:2px dashed var(--border2);border-radius:var(--radius);
  height:180px;display:flex;align-items:center;justify-content:center;
  margin-bottom:18px;font-size:13px;color:var(--text3);}
.modal-foot{padding:14px 20px;border-top:1px solid var(--border);
  display:flex;gap:8px;background:var(--surface);}

/* ══ RECEIPT PRINT ══ */
.receipt-print{background:var(--white);border:3px solid var(--navy);border-radius:var(--radius);
  padding:28px;max-width:400px;margin:0 auto;}
.receipt-print h2{font-family:'Noto Serif KR',serif;font-size:24px;font-weight:900;
  letter-spacing:6px;text-align:center;border-bottom:3px solid var(--navy);
  padding-bottom:12px;margin-bottom:20px;}
.receipt-row{margin-bottom:12px;border-bottom:1px solid var(--border);padding-bottom:10px;}
.receipt-row label{font-size:13px;font-weight:800;display:inline-block;width:60px;}
.receipt-row span{font-size:13px;}
.receipt-date{text-align:center;margin:20px 0;font-size:14px;}
.receipt-signs{display:flex;justify-content:center;gap:40px;margin-top:20px;}
.receipt-sign{text-align:center;}
.receipt-sign .lbl{font-size:13px;font-weight:800;margin-bottom:6px;}
.receipt-sign .sign-box{width:80px;height:40px;border:2px solid var(--navy);
  border-radius:4px;display:flex;align-items:center;justify-content:center;
  font-size:11px;color:var(--text3);}

/* ══ NOTIFICATION ══ */
.notif{position:fixed;bottom:24px;right:24px;background:var(--navy);color:white;
  border-radius:var(--radius);padding:14px 20px;min-width:280px;z-index:3000;
  display:none;box-shadow:var(--shadow2);font-size:13px;}
.notif.show{display:block;animation:slideUp .3s ease;}
@keyframes slideUp{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
.nt{font-weight:800;margin-bottom:3px;font-size:14px;}

/* ══ AUDIT PERIOD BANNER ══ */
.audit-banner{background:linear-gradient(135deg,#4a1a7a,#6b4c9a);
  color:white;padding:12px 18px;border-radius:var(--radius);margin-bottom:16px;
  display:flex;align-items:center;gap:12px;box-shadow:var(--shadow);}
.audit-banner .ico{font-size:24px;}
.audit-banner .txt h4{font-size:14px;font-weight:800;}
.audit-banner .txt p{font-size:12px;opacity:.8;margin-top:2px;}

/* ══ CARRYOVER ══ */
.carry-bar{background:var(--gold-light);border:2px solid var(--gold);
  border-radius:var(--radius);padding:12px 18px;margin-bottom:14px;
  display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.carry-bar label{font-size:12px;color:var(--gold);font-weight:800;}
.carry-bar input{padding:7px 10px;border:2px solid var(--gold);border-radius:var(--radius2);
  font-size:13px;font-family:inherit;width:180px;outline:none;}
.carry-bar span{font-size:11px;color:var(--text3);}

/* ══ MOBILE ══ */
@media(max-width:768px){
  .sidebar{transform:translateX(-100%);}
  .sidebar.open{transform:translateX(0);box-shadow:var(--shadow2);}
  .main{margin-left:0;}
  .page{padding:14px;}
  .sc{grid-template-columns:1fr 1fr;}
  .fgrid{grid-template-columns:1fr;}
  table{font-size:11px;}
  th,td{padding:7px 6px;}
  .flow{gap:0;}
  .flow-step{min-width:70px;}
}
</style>
</head>
<body>

<!-- ══ STEP 1: 통합 입구 ══ -->
<div id="step1">
  <div class="s1-box">
    <div class="s1-logo">
      <span class="cross">✝️</span>
      <h1>교회 회계 장부 시스템</h1>
      <p>Church Financial Management System</p>
      <span class="ver">v3.0</span>
    </div>
    <div class="ig"><label>통합 아이디</label>
      <input type="text" id="s1id" placeholder="아이디 입력" value="church2025">
    </div>
    <div class="ig"><label>비밀번호</label>
      <input type="password" id="s1pw" placeholder="비밀번호 입력" value="1234"
             onkeydown="if(event.key==='Enter')step1Login()">
    </div>
    <button class="btn-login" onclick="step1Login()">입장하기</button>
    <p class="hint">통합 ID: church2025 / PW: 1234</p>
  </div>
</div>

<!-- ══ STEP 2: 위원회 선택 ══ -->
<div id="step2">
  <div class="s2-header">
    <h2>✝️ 소속 위원회를 선택하세요</h2>
    <p>해당 위원회 버튼을 클릭하면 로그인 화면으로 이동합니다</p>
  </div>
  <div class="s2-body">
    <div class="s2-section">
      <div class="nsl">위원회 선택</div>
      <div class="comm-grid" id="commGrid"></div>
    </div>
    <div class="s2-section">
      <div class="nsl">특별 계정</div>
      <div class="special-tiles" id="specialTiles"></div>
    </div>
  </div>
</div>

<!-- ══ STEP 3: 위원회 로그인 ══ -->
<div id="step3" style="display:flex">
  <div class="s3-box" style="display:none" id="s3box">
    <button class="s3-back" onclick="goStep2()">← 위원회 선택으로 돌아가기</button>
    <div class="s3-comm-badge">
      <span class="ico" id="s3ico">🏛️</span>
      <div>
        <h3 id="s3name">위원회명</h3>
        <p id="s3sub">아이디와 비밀번호를 입력하세요</p>
      </div>
    </div>
    <div class="role-hint">
      <p>🔑 이 위원회 계정 (아이디/비밀번호)</p>
      <div class="role-list" id="roleList"></div>
      <div style="margin-top:8px;padding-top:8px;border-top:1px dashed #ddd;font-size:10px;color:#aaa">
        📌 ID 체계: 위원회코드_역할 (예: edu_mid_acc)<br>
        📌 PW 체계: 위원회코드+1234 (예: edu1234)
      </div>
    </div>
    <div class="ig"><label>아이디</label>
      <input type="text" id="s3id" placeholder="아이디 입력">
    </div>
    <div class="ig"><label>비밀번호</label>
      <input type="password" id="s3pw" placeholder="비밀번호 입력"
             onkeydown="if(event.key==='Enter')step3Login()">
    </div>
    <button class="btn-login" onclick="step3Login()">로그인</button>
  </div>
</div>

<!-- ══ APP ══ -->
<div id="app">
  <div class="topbar">
    <button class="menu-btn" onclick="toggleSidebar()">☰</button>
    <div class="topbar-title">✝️ 교회 회계 장부 v3.0</div>
    <div class="topbar-user">
      <strong id="tbName">-</strong>
      <span id="tbComm">-</span>
    </div>
  </div>

  <div class="sidebar" id="sidebar">
    <div class="ns">
      <div class="nsl">장부관리</div>
      <button class="nb active" onclick="sp('ledger',this)"><span class="ico">📒</span>지출 입력장부</button>
      <button class="nb" onclick="sp('monthly',this)"><span class="ico">📅</span>월간 현황</button>
      <button class="nb" onclick="sp('annual',this)"><span class="ico">📊</span>연간 현황</button>
      <button class="nb" onclick="sp('integrated',this)" id="nav-integrated"><span class="ico">📈</span>통합 현황</button>
    </div>
    <div class="ndiv"></div>
    <div class="ns">
      <div class="nsl">결의서/결재</div>
      <button class="nb" onclick="sp('voucher',this)"><span class="ico">📋</span>지출결의서</button>
      <button class="nb" onclick="sp('approval',this)"><span class="ico">✅</span>전자결재함<span class="badge" id="abadge" style="display:none">2</span></button>
    </div>
    <div class="ndiv"></div>
    <div class="ns">
      <div class="nsl">특별활동</div>
      <button class="nb" onclick="sp('special',this)"><span class="ico">🎯</span>특별활동 장부</button>
    </div>
    <div class="ndiv"></div>
    <div class="ns" id="nav-pastor" style="display:none">
      <div class="nsl">당회장</div>
      <button class="nb" onclick="sp('pastor',this)"><span class="ico">👑</span>결의서 사후승인<span class="badge" id="pbadge">5</span></button>
    </div>
    <div class="ndiv" id="ndiv-pastor" style="display:none"></div>
    <div class="ns" id="nav-audit" style="display:none">
      <div class="nsl">감사</div>
      <button class="nb" onclick="sp('audit',this)"><span class="ico">🔍</span>감사 확인</button>
    </div>
    <div class="ndiv" id="ndiv-audit" style="display:none"></div>
    <div class="ns" id="nav-admin" style="display:none">
      <div class="nsl">관리자</div>
      <button class="nb" onclick="sp('budget',this)"><span class="ico">💰</span>예산 관리</button>
      <button class="nb" onclick="sp('users',this)"><span class="ico">👥</span>사용자/권한</button>
      <button class="nb" onclick="sp('audit-period',this)"><span class="ico">📆</span>감사기간 설정</button>
      <button class="nb" onclick="sp('settings',this)"><span class="ico">⚙️</span>시스템 설정</button>
    </div>
    <div class="ndiv"></div>
    <div class="ns">
      <button class="nb" onclick="doLogout()" style="color:var(--red)"><span class="ico">🚪</span>로그아웃</button>
    </div>
  </div>

  <div class="main">

    <!-- 📒 지출 입력장부 -->
    <div class="page active" id="page-ledger">
      <div class="print-header"><h2 id="printTitle">2025년도 예산집행현황</h2><p>(단위: 원) B5</p></div>
      <div class="ph">
        <div class="ph-left"><h2>📒 지출 입력장부</h2></div>
        <div class="ph-right no-print">
          <button class="btn bp" onclick="toggleExpForm()">+ 지출 입력</button>
          <button class="btn bpr" onclick="showPrintModal('ledger')">🖨️ 인쇄</button>
        </div>
      </div>

      <!-- 감사 배너 -->
      <div class="audit-banner no-print" id="auditBanner" style="display:none">
        <span class="ico">🔍</span>
        <div class="txt">
          <h4>감사 진행 중</h4>
          <p id="auditBannerMsg">감사위원회 정기감사가 진행 중입니다</p>
        </div>
      </div>

      <div class="fb no-print">
        <label>위원회</label>
        <select id="selComm" onchange="onCommChange()"></select>
        <label>부서</label>
        <select id="selDept" onchange="onDeptChange()" style="max-width:260px"></select>
        <span id="deptBudgetBadge" style="background:var(--blue-light);color:var(--blue);padding:5px 10px;border-radius:8px;font-size:12px;font-weight:800;display:none"></span>
        <label>월</label>
        <select id="selMon" onchange="renderLedger()">
          <option>전체</option>
          <option selected>2월</option>
          <option>3월</option><option>4월</option><option>5월</option>
          <option>6월</option><option>7월</option><option>8월</option>
          <option>9월</option><option>10월</option><option>11월</option><option>12월</option>
        </select>
      </div>

      <div class="carry-bar no-print">
        <label>📌 이월금 (수기입력)</label>
        <input type="number" id="carryAmt" placeholder="전년도 이월금액 (원)" oninput="renderLedger()">
        <span>※ 이월금은 수기기록 → 잔액 자동반영</span>
      </div>

      <div class="sc">
        <div class="scard cb"><div class="lbl">📌 연간 예산</div><div class="val vb" id="cBudget">-</div><div class="sub">원</div></div>
        <div class="scard co"><div class="lbl">📌 이월금</div><div class="val vo" id="cCarry">0</div><div class="sub">원</div></div>
        <div class="scard cr"><div class="lbl">💸 총 지출</div><div class="val vr" id="cExp">-</div><div class="sub">원</div><div class="prog"><div class="pf pfr" id="cProg" style="width:0%"></div></div></div>
        <div class="scard cg"><div class="lbl">💰 잔액</div><div class="val vg" id="cBal">-</div><div class="sub">원</div></div>
      </div>

      <!-- 지출 입력 폼 -->
      <div class="fc no-print" id="expForm" style="display:none">
        <div class="fch">✏️ 지출 입력</div>
        <div class="fb2">
          <div class="fgrid">
            <div class="fg"><label>날짜 *</label><input type="date" id="fDate"></div>
            <div class="fg"><label>항목 *</label>
              <select id="fCat" onchange="onCatChange()"><option value="">-- 항목 선택 --</option></select>
            </div>
            <div class="fg full"><label>세부항목 *</label>
              <select id="fDetail"><option value="">-- 세부항목 선택 --</option></select>
            </div>
            <div class="fg full"><label>적요 (상세내용) *</label>
              <input type="text" id="fMemo" placeholder="예) 찬양팀 간식비, 임원 MT 교통비">
            </div>
            <div class="fg"><label>수입 (원)</label><input type="number" id="fInc" placeholder="0"></div>
            <div class="fg"><label>지출 (원)</label><input type="number" id="fExp" placeholder="0"></div>
            <div class="fg"><label>영수증 번호</label><input type="text" id="fRno" placeholder="자동생성"></div>
            <div class="fg"><label>📷 영수증 촬영/첨부</label>
              <input type="file" id="fReceipt" accept="image/*" capture="environment" style="display:none" onchange="onReceiptChg()">
              <button type="button" class="btn bo" style="width:100%" onclick="document.getElementById('fReceipt').click()">📷 카메라 촬영 / 파일 선택</button>
              <div id="rcvPreview" style="font-size:11px;color:var(--green);margin-top:4px;display:none"></div>
            </div>
          </div>
        </div>
        <div class="faction">
          <button class="btn bp" onclick="submitExp()">💾 저장 및 결재신청</button>
          <button class="btn bo" onclick="saveDraft()">📝 임시저장</button>
          <button class="btn bo" onclick="toggleExpForm()">취소</button>
        </div>
      </div>

      <div class="tw">
        <div class="th"><h3 id="ledgerTableTitle">📋 지출내역</h3>
          <span style="font-size:11px;color:var(--text3)" class="no-print">영수증 클릭→상세 | 감사체크→서명</span>
        </div>
        <div class="ts"><table>
          <thead><tr>
            <th>날짜</th><th>항목</th><th>세부항목</th><th>적요</th>
            <th>영수증</th><th>수입</th><th>지출</th><th>잔액</th>
            <th>결재</th><th class="no-print">감사확인</th>
          </tr></thead>
          <tbody id="ledgerBody"></tbody>
        </table></div>
      </div>
    </div>

    <!-- 📅 월간현황 -->
    <div class="page" id="page-monthly">
      <div class="print-header"><h2 id="monthlyPrintTitle">2025년 월간 현황</h2><p>(단위: 원)</p></div>
      <div class="ph">
        <div class="ph-left"><h2>📅 월간 현황</h2><p id="monthlySub">월간 항목별 현황</p></div>
        <div class="ph-right no-print">
          <button class="btn bpr" onclick="showPrintModal('monthly')">🖨️ 인쇄</button>
        </div>
      </div>
      <div class="sc" id="monthlyCards"></div>
      <div class="tw">
        <div class="th"><h3>항목별 지출 현황</h3>
          <div class="no-print" id="auditSignBtn" style="display:none">
            <button class="btn bs btn-sm" onclick="auditSign('monthly')">🔍 감사 확인 서명</button>
          </div>
        </div>
        <div class="ts"><table>
          <thead><tr><th>항목</th><th>세부항목</th><th>건수</th><th>지출액</th><th>비율</th></tr></thead>
          <tbody id="monthlyBody"></tbody>
        </table></div>
        <div id="auditSignedInfo" style="display:none;padding:12px 18px;background:var(--green-light);
          border-top:1px solid var(--border);font-size:12px;color:var(--green);font-weight:700;"></div>
      </div>
    </div>

    <!-- 📊 연간현황 -->
    <div class="page" id="page-annual">
      <div class="print-header"><h2 id="annualPrintTitle">2025년도 연간 예산집행현황</h2><p>(단위: 원) B5 가로</p></div>
      <div class="ph">
        <div class="ph-left"><h2>📊 연간 현황</h2><p>2025년도 연간 예산집행현황</p></div>
        <div class="ph-right no-print">
          <button class="btn bpr" onclick="showPrintModal('annual')">🖨️ 인쇄 (B5)</button>
        </div>
      </div>
      <div class="tw">
        <div class="th"><h3 id="annualTableTitle">연간 예산집행현황 (단위: 원)</h3>
          <div class="no-print" id="auditSignBtn2" style="display:none">
            <button class="btn bs btn-sm" onclick="auditSign('annual')">🔍 연간 감사 서명</button>
          </div>
        </div>
        <div class="ts"><table id="annualTable">
          <thead><tr id="annualHead"></tr></thead>
          <tbody id="annualBody"></tbody>
        </table></div>
      </div>
    </div>

    <!-- 📈 통합현황 -->
    <div class="page" id="page-integrated">
      <div class="ph">
        <div class="ph-left"><h2>📈 통합 현황</h2><p>전체 위원회 예산집행 통합현황</p></div>
        <div class="ph-right no-print"><button class="btn bpr" onclick="showPrintModal('integrated')">🖨️ 인쇄</button></div>
      </div>
      <div class="sc">
        <div class="scard cb"><div class="lbl">전체 예산</div><div class="val vb">470,000,000</div><div class="sub">원</div></div>
        <div class="scard cr"><div class="lbl">전체 지출</div><div class="val vr">89,250,000</div><div class="sub">원 (19%)</div><div class="prog"><div class="pf pfr" style="width:19%"></div></div></div>
        <div class="scard cg"><div class="lbl">전체 잔액</div><div class="val vg">380,750,000</div><div class="sub">원</div></div>
        <div class="scard co"><div class="lbl">결재대기</div><div class="val vo">7</div><div class="sub">건 전체</div></div>
      </div>
      <div class="tw">
        <div class="th"><h3>위원회별 예산집행 현황</h3></div>
        <div class="ts"><table>
          <thead><tr><th>위원회</th><th>예산</th><th>지출</th><th>잔액</th><th>집행률</th><th>상태</th></tr></thead>
          <tbody id="intBody"></tbody>
        </table></div>
      </div>
    </div>

    <!-- 📋 지출결의서 -->
    <div class="page" id="page-voucher">
      <div class="ph">
        <div class="ph-left"><h2>📋 지출결의서</h2><p>지출 결재 신청 및 현황</p></div>
        <div class="ph-right no-print">
          <button class="btn bp" onclick="toggleVoucher()">+ 새 결의서 작성</button>
          <button class="btn bpr" onclick="showPrintModal('voucher')">🖨️ 인쇄</button>
        </div>
      </div>

      <!-- 결재 흐름 -->
      <div class="fc no-print">
        <div class="fch">📌 전자결재 7단계 흐름</div>
        <div class="fb2" style="padding:16px;">
          <div class="flow" id="approvalFlow"></div>
        </div>
      </div>

      <!-- 결의서 작성 폼 -->
      <div class="fc" id="voucherForm" style="display:none">
        <div class="fch">✏️ 지출결의서 작성</div>
        <div class="fb2">
          <!-- 결의서 양식 -->
          <div class="voucher" id="voucherPreview">
            <div class="voucher-title">
              <h2>지 출 결 의 서</h2>
            </div>
            <div class="voucher-info">
              <div>
                <p style="font-size:13px;font-weight:700">위원회: <span id="vComm">-</span> 위원회</p>
                <p style="font-size:13px;font-weight:700;margin-top:5px">부&nbsp;&nbsp;&nbsp;서: <span id="vDept">-</span></p>
              </div>
              <table class="voucher-approval">
                <tr>
                  <th>결</th><th>회&nbsp;&nbsp;계</th><th>부&nbsp;&nbsp;장</th><th>위원장</th>
                </tr>
