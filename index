    {date:"02/22",cat:"소모품",memo:"텐트나눔 준비물",rno:"29",expense:35000,status:"approved"},
    {date:"02/23",cat:"행사",memo:"오리엔테이션",rno:"37",expense:80000,status:"pending"},
    {date:"02/24",cat:"레크",memo:"레크레이션(1)",rno:"39",expense:150000,status:"approved"},
    {date:"02/24",cat:"레크",memo:"레크레이션(2)",rno:"40",expense:120000,status:"approved"},
  ];
  const tbody=document.getElementById('specBody');tbody.innerHTML='';
  let bal=5000000;
  const smap={approved:'<span class="sb sb-ok">✓ 승인</span>',pending:'<span class="sb sb-wait">⏳ 대기</span>'};
  const isAuditEnabled=auditActive&&(CU?CU.role==='auditor'||['master','sub_master'].includes(CU.role):false);
  data.forEach((row,i)=>{
    bal-=row.expense;
    const auditCell=isAuditEnabled?
      `<input type="radio" name="saudit_${i}" title="감사확인">`:
      `<span style="font-size:10px;color:var(--text3)">—</span>`;
    const tr=document.createElement('tr');
    tr.innerHTML=`<td class="tc">${row.date}</td><td>${row.cat}</td><td>${row.memo}</td>
      <td class="tc"><span class="sb sb-draft" style="cursor:pointer" onclick="showRec('R-${row.rno.padStart(4,'0')}','${row.date}','${row.cat}','${row.memo}','${row.expense}')">🧾 #${row.rno}</span></td>
