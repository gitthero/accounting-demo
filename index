      <td class="tc">${smap[row.status]}</td>
      <td class="tc no-print">${auditCell}</td>`;
    tbody.appendChild(tr);
  });
  const total=data.reduce((a,r)=>a+r.expense,0);
  const sub=document.createElement('tr');sub.className='tsub';
  sub.innerHTML=`<td colspan="4" class="tc">소 계</td><td class="tnum" style="color:var(--red)">${total.toLocaleString()}</td><td class="tnum">${(5000000-total).toLocaleString()}</td><td></td><td class="no-print"></td>`;
  tbody.appendChild(sub);
}

